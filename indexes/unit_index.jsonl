{"id": "bridge:bulk-boundary-correspondence-to-fermi-arc", "type": "bridge", "title": "Bulk-Boundary Correspondence To Fermi Arc", "summary": "The same bulk topology that assigns charges to Weyl nodes reorganizes boundary spectra into open Fermi arcs, so the arc is a boundary projection of changing bulk topological data.", "path": "units/bridges/bulk-boundary-correspondence-to-fermi-arc.json", "domain": "topological-phases-of-matter", "subdomain": "bridge-objects", "tags": ["bridge", "bulk-boundary", "fermi-arc"], "aliases": [], "dependencies": ["concept:weyl-node", "concept:fermi-arc"], "related_units": ["claim:fermi-arcs-terminate-at-projected-weyl-nodes"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 2}
{"id": "bridge:continuum-anomaly-to-lattice-no-go", "type": "bridge", "title": "Continuum Anomaly To Lattice No-Go", "summary": "The continuum fact that a lone charged chiral fermion is anomalous motivates the lattice theorem that a globally consistent band structure cannot realize an unmatched net chirality.", "path": "units/bridges/continuum-anomaly-to-lattice-no-go.json", "domain": "topological-phases-of-matter", "subdomain": "bridge-objects", "tags": ["bridge", "anomaly", "nielsen-ninomiya"], "aliases": [], "dependencies": ["concept:nielsen-ninomiya-theorem", "claim:lattice-weyl-nodes-sum-to-zero-net-chirality"], "related_units": ["warning:local-weyl-description-does-not-fix-global-lattice-consistency"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "bridge:weyl-node-to-berry-monopole", "type": "bridge", "title": "Weyl Node To Berry Monopole", "summary": "A Weyl node can be read either as a linearized band crossing or as a momentum-space monopole of Berry curvature whose flux equals the node charge.", "path": "units/bridges/weyl-node-to-berry-monopole.json", "domain": "topological-phases-of-matter", "subdomain": "bridge-objects", "tags": ["bridge", "weyl-node", "berry-curvature"], "aliases": [], "dependencies": ["concept:weyl-node", "concept:berry-curvature", "equation:berry-flux-topological-charge"], "related_units": ["concept:chirality-of-weyl-node", "method:berry-flux-diagnosis-of-node-charge"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "claim:fermi-arcs-terminate-at-projected-weyl-nodes", "type": "claim", "title": "Fermi Arcs Terminate At Projected Weyl Nodes", "summary": "The endpoints of a Fermi arc in the surface Brillouin zone are fixed by the projections of bulk Weyl nodes that source the changing topological data across momentum slices.", "path": "units/claims/fermi-arcs-terminate-at-projected-weyl-nodes.json", "domain": "topological-phases-of-matter", "subdomain": "boundary-phenomena", "tags": ["fermi-arc", "bulk-boundary", "weyl-semimetal"], "aliases": [], "dependencies": ["concept:fermi-arc", "concept:weyl-node", "bridge:bulk-boundary-correspondence-to-fermi-arc"], "related_units": ["warning:crossing-away-from-fermi-energy-is-not-yet-a-clean-weyl-semimetal"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "claim:generic-2d-dirac-points-require-symmetry-protection", "type": "claim", "title": "Generic 2D Dirac Points Require Symmetry Protection", "summary": "Unlike isolated two-band crossings in three dimensions, two-dimensional Dirac points are generally not stable without extra symmetry or special structure.", "path": "units/claims/generic-2d-dirac-points-require-symmetry-protection.json", "domain": "topological-phases-of-matter", "subdomain": "dirac-materials", "tags": ["2d-dirac", "symmetry-protection", "genericity"], "aliases": [], "dependencies": ["concept:dirac-point-in-2d", "concept:band-crossing"], "related_units": ["claim:isolated-3d-two-band-crossings-are-weyl-nodes"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 2}
{"id": "claim:isolated-3d-two-band-crossings-are-weyl-nodes", "type": "claim", "title": "Isolated 3D Two-Band Crossings Are Weyl Nodes", "summary": "A generic isolated two-band crossing in three dimensions linearizes to a Weyl Hamiltonian, with chirality given by the sign of the Jacobian determinant.", "path": "units/claims/isolated-3d-two-band-crossings-are-weyl-nodes.json", "domain": "topological-phases-of-matter", "subdomain": "weyl-semimetals", "tags": ["weyl-node", "genericity", "3d-crossing"], "aliases": [], "dependencies": ["concept:band-crossing", "concept:weyl-node", "quantity:chirality-sign"], "related_units": ["claim:generic-2d-dirac-points-require-symmetry-protection"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "claim:lattice-weyl-nodes-sum-to-zero-net-chirality", "type": "claim", "title": "Lattice Weyl Nodes Sum To Zero Net Chirality", "summary": "In a lattice system with isolated Weyl nodes, the total chirality over the Brillouin zone vanishes; positive and negative nodes must balance globally.", "path": "units/claims/lattice-weyl-nodes-sum-to-zero-net-chirality.json", "domain": "topological-phases-of-matter", "subdomain": "lattice-topology", "tags": ["nielsen-ninomiya", "fermion-doubling", "chirality-cancellation"], "aliases": [], "dependencies": ["concept:nielsen-ninomiya-theorem", "quantity:chirality-sign", "quantity:winding-number"], "related_units": ["warning:local-weyl-description-does-not-fix-global-lattice-consistency", "bridge:continuum-anomaly-to-lattice-no-go"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 2}
{"id": "concept:band-crossing", "type": "concept", "title": "Band Crossing", "summary": "A band crossing is a momentum-space point where two energy bands become degenerate; in Lecture One it is the local seed from which Weyl and Dirac low-energy descriptions are extracted.", "path": "units/concepts/band-crossing.json", "domain": "topological-phases-of-matter", "subdomain": "lecture-one", "tags": ["band-theory", "degeneracy", "topological-phases"], "aliases": ["band touching", "gap crossing"], "dependencies": [], "related_units": ["concept:weyl-node", "concept:dirac-point-in-2d", "claim:isolated-3d-two-band-crossings-are-weyl-nodes"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "concept:berry-connection", "type": "concept", "title": "Berry Connection", "summary": "The Berry connection is the U(1) connection on the line bundle of occupied states over regular momentum space, encoding phase transport of eigenstates along paths.", "path": "units/concepts/berry-connection.json", "domain": "topological-phases-of-matter", "subdomain": "berry-geometry", "tags": ["berry-phase", "line-bundle", "connection"], "aliases": ["Berry gauge field"], "dependencies": ["concept:complex-line-bundle-of-filled-states"], "related_units": ["concept:berry-curvature", "equation:berry-flux-topological-charge", "quantity:berry-curvature-two-form"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "concept:berry-curvature", "type": "concept", "title": "Berry Curvature", "summary": "Berry curvature is the curvature two-form of the Berry connection; in Lecture One its flux through a sphere around a bad point measures the node's topological charge.", "path": "units/concepts/berry-curvature.json", "domain": "topological-phases-of-matter", "subdomain": "berry-geometry", "tags": ["berry-curvature", "topological-charge", "weyl-semimetal"], "aliases": [], "dependencies": ["concept:berry-connection", "quantity:berry-curvature-two-form"], "related_units": ["concept:weyl-node", "quantity:winding-number", "derivation:berry-flux-gives-node-charge"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "concept:chirality-of-weyl-node", "type": "concept", "title": "Chirality Of A Weyl Node", "summary": "The chirality of a Weyl node is the sign of the Jacobian relating momentum deviations to the Pauli-vector coefficients in the local Hamiltonian, equivalently the sign of its Berry-flux charge.", "path": "units/concepts/chirality-of-weyl-node.json", "domain": "topological-phases-of-matter", "subdomain": "weyl-semimetals", "tags": ["chirality", "weyl-semimetal", "topological-charge"], "aliases": ["handedness of a Weyl node"], "dependencies": ["concept:weyl-node", "quantity:chirality-sign", "quantity:winding-number"], "related_units": ["equation:berry-flux-topological-charge", "equation:two-band-hamiltonian-d-dot-sigma", "bridge:weyl-node-to-berry-monopole"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 2}
{"id": "concept:complex-line-bundle-of-filled-states", "type": "concept", "title": "Complex Line Bundle Of Filled States", "summary": "For a two-band system with one filled band, the occupied state at each regular momentum defines a one-dimensional complex vector space; together these fibers form the line bundle on which the Berry connection lives.", "path": "units/concepts/complex-line-bundle-of-filled-states.json", "domain": "topological-phases-of-matter", "subdomain": "berry-geometry", "tags": ["line-bundle", "filled-bands", "berry-geometry"], "aliases": ["occupied-state bundle"], "dependencies": [], "related_units": ["concept:berry-connection", "concept:berry-curvature"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "concept:dirac-point-in-2d", "type": "concept", "title": "Dirac Point In Two Dimensions", "summary": "A two-dimensional Dirac point is a linear band crossing in 2D whose generic persistence usually requires extra symmetry or special tuning rather than only codimension counting.", "path": "units/concepts/dirac-point-in-2d.json", "domain": "topological-phases-of-matter", "subdomain": "dirac-materials", "tags": ["dirac-point", "2d-materials", "symmetry-protection"], "aliases": [], "dependencies": ["concept:band-crossing"], "related_units": ["claim:generic-2d-dirac-points-require-symmetry-protection", "warning:crossing-away-from-fermi-energy-is-not-yet-a-clean-weyl-semimetal"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "concept:fermi-arc", "type": "concept", "title": "Fermi Arc", "summary": "A Fermi arc is a surface-state locus in boundary momentum space whose endpoints lie at the projections of bulk Weyl nodes of opposite total charge.", "path": "units/concepts/fermi-arc.json", "domain": "topological-phases-of-matter", "subdomain": "boundary-phenomena", "tags": ["fermi-arc", "boundary-mode", "weyl-semimetal"], "aliases": [], "dependencies": ["concept:weyl-node"], "related_units": ["claim:fermi-arcs-terminate-at-projected-weyl-nodes", "bridge:bulk-boundary-correspondence-to-fermi-arc"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "concept:nielsen-ninomiya-theorem", "type": "concept", "title": "Nielsen-Ninomiya Theorem", "summary": "For a lattice band structure with isolated Weyl crossings, the sum of all node charges over the Brillouin zone is zero, forbidding a net chirality in a strictly lattice-regularized system.", "path": "units/concepts/nielsen-ninomiya-theorem.json", "domain": "topological-phases-of-matter", "subdomain": "lattice-topology", "tags": ["nielsen-ninomiya", "fermion-doubling", "weyl-semimetal"], "aliases": ["fermion doubling theorem"], "dependencies": ["concept:weyl-node", "quantity:winding-number", "derivation:stokes-theorem-implies-net-zero-charge"], "related_units": ["claim:lattice-weyl-nodes-sum-to-zero-net-chirality", "warning:local-weyl-description-does-not-fix-global-lattice-consistency", "bridge:continuum-anomaly-to-lattice-no-go"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 2}
{"id": "concept:weyl-node", "type": "concept", "title": "Weyl Node", "summary": "A Weyl node is an isolated three-dimensional two-band crossing whose linearized Hamiltonian is a Weyl Hamiltonian and whose local topological charge is nonzero.", "path": "units/concepts/weyl-node.json", "domain": "topological-phases-of-matter", "subdomain": "weyl-semimetals", "tags": ["weyl-semimetal", "band-crossing", "chirality"], "aliases": ["Weyl point", "Weyl crossing"], "dependencies": ["concept:band-crossing", "equation:two-band-hamiltonian-d-dot-sigma", "quantity:chirality-sign"], "related_units": ["concept:chirality-of-weyl-node", "concept:berry-curvature", "bridge:weyl-node-to-berry-monopole", "warning:local-weyl-description-does-not-fix-global-lattice-consistency"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "derivation:berry-flux-gives-node-charge", "type": "derivation", "title": "Berry Flux Gives Node Charge", "summary": "Once the occupied states are organized into a line bundle, the flux of Berry curvature through a small sphere around a bad point yields the node's integer topological charge.", "path": "units/derivations/berry-flux-gives-node-charge.json", "domain": "topological-phases-of-matter", "subdomain": "berry-geometry", "tags": ["derivation", "berry-flux", "topological-charge"], "aliases": [], "dependencies": ["concept:berry-connection", "concept:berry-curvature", "equation:berry-flux-topological-charge"], "related_units": ["bridge:weyl-node-to-berry-monopole", "concept:chirality-of-weyl-node"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "derivation:linearization-gives-1d-chiral-mode", "type": "derivation", "title": "Linearization Gives A 1D Chiral Mode", "summary": "Linearizing the dispersion around a one-dimensional Fermi crossing and replacing momentum deviation by -i d/dx yields a continuum chiral Hamiltonian whose sign of velocity fixes the branch direction.", "path": "units/derivations/linearization-gives-1d-chiral-mode.json", "domain": "topological-phases-of-matter", "subdomain": "lecture-one", "tags": ["derivation", "linearization", "1d-chiral-mode"], "aliases": [], "dependencies": ["equation:linearized-dispersion-near-fermi-point", "equation:continuum-1d-chiral-fermion-hamiltonian", "quantity:fermi-velocity"], "related_units": ["warning:local-weyl-description-does-not-fix-global-lattice-consistency"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "derivation:stokes-theorem-implies-net-zero-charge", "type": "derivation", "title": "Stokes's Theorem Implies Net Zero Charge", "summary": "Because the relevant form is closed on the punctured Brillouin zone, integrating its exterior derivative over the punctured region and applying Stokes's theorem yields that the sum of boundary charges around all bad points is zero.", "path": "units/derivations/stokes-theorem-implies-net-zero-charge.json", "domain": "topological-phases-of-matter", "subdomain": "lattice-topology", "tags": ["stokes-theorem", "nielsen-ninomiya", "global-constraint"], "aliases": [], "dependencies": ["equation:winding-number-as-s2-to-s2-degree", "equation:berry-flux-topological-charge", "concept:nielsen-ninomiya-theorem"], "related_units": ["claim:lattice-weyl-nodes-sum-to-zero-net-chirality"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 2}
{"id": "equation:berry-flux-topological-charge", "type": "equation", "title": "Berry Flux Equals Topological Charge", "summary": "For an isolated bad point, the integral of Berry curvature over a small surrounding sphere equals the integer topological charge of the node.", "path": "units/equations/berry-flux-topological-charge.json", "domain": "topological-phases-of-matter", "subdomain": "berry-geometry", "tags": ["berry-flux", "weyl-node", "topological-charge"], "aliases": [], "dependencies": ["concept:berry-curvature", "quantity:berry-curvature-two-form", "quantity:winding-number"], "related_units": ["bridge:weyl-node-to-berry-monopole", "derivation:berry-flux-gives-node-charge", "concept:chirality-of-weyl-node"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "equation:continuum-1d-chiral-fermion-hamiltonian", "type": "equation", "title": "Continuum 1D Chiral Fermion Hamiltonian", "summary": "After replacing p-p0 by -i d/dx, the linearized one-dimensional crossing becomes a continuum Hamiltonian H=v integral dx psi* (-i d/dx) psi up to an irrelevant constant shift.", "path": "units/equations/continuum-1d-chiral-fermion-hamiltonian.json", "domain": "topological-phases-of-matter", "subdomain": "lecture-one", "tags": ["chiral-fermion", "continuum-hamiltonian", "1d"], "aliases": [], "dependencies": ["equation:linearized-dispersion-near-fermi-point"], "related_units": ["derivation:linearization-gives-1d-chiral-mode"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "stable", "source_anchor_count": 1}
{"id": "equation:linearized-dispersion-near-fermi-point", "type": "equation", "title": "Linearized Dispersion Near A Fermi Point", "summary": "Near an isolated one-dimensional Fermi crossing, the band energy expands linearly as epsilon(p)=epsilon(p0)+v(p-p0)+O((p-p0)^2).", "path": "units/equations/linearized-dispersion-near-fermi-point.json", "domain": "topological-phases-of-matter", "subdomain": "lecture-one", "tags": ["linearization", "fermi-point", "continuum-limit"], "aliases": [], "dependencies": ["quantity:fermi-velocity"], "related_units": ["equation:continuum-1d-chiral-fermion-hamiltonian", "derivation:linearization-gives-1d-chiral-mode"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "stable", "source_anchor_count": 1}
{"id": "equation:two-band-hamiltonian-d-dot-sigma", "type": "equation", "title": "Two-Band Hamiltonian A Plus B Dot Sigma", "summary": "A generic local two-band Hamiltonian can be written as H(p)=a(p)+b(p).sigma, and after subtracting the scalar part the crossing structure is governed by the vector b(p).", "path": "units/equations/two-band-hamiltonian-d-dot-sigma.json", "domain": "topological-phases-of-matter", "subdomain": "weyl-semimetals", "tags": ["two-band-model", "pauli-matrices", "weyl-node"], "aliases": ["a plus b dot sigma form"], "dependencies": [], "related_units": ["concept:weyl-node", "equation:berry-flux-topological-charge"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "stable", "source_anchor_count": 1}
{"id": "equation:two-band-weyl-model-with-tunable-pair", "type": "equation", "title": "Two-Band Weyl Model With A Tunable Pair", "summary": "The toy Hamiltonian with off-diagonal p1 plus or minus i p2 and diagonal plus or minus f(p3) realizes Weyl nodes whose creation, motion, and annihilation are controlled by the zeros of f.", "path": "units/equations/two-band-weyl-model-with-tunable-pair.json", "domain": "topological-phases-of-matter", "subdomain": "toy-models", "tags": ["toy-model", "weyl-semimetal", "pair-annihilation"], "aliases": [], "dependencies": ["concept:weyl-node"], "related_units": ["model:two-band-lattice-weyl-model", "warning:local-weyl-description-does-not-fix-global-lattice-consistency"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "equation:winding-number-as-s2-to-s2-degree", "type": "equation", "title": "Winding Number As The Degree Of S2 To S2", "summary": "The topological charge of an isolated bad point is the degree of the map from a small enclosing sphere in momentum space to the target sphere of normalized b-vectors.", "path": "units/equations/winding-number-as-s2-to-s2-degree.json", "domain": "topological-phases-of-matter", "subdomain": "topological-charge", "tags": ["winding-number", "degree", "s2-to-s2"], "aliases": [], "dependencies": ["quantity:winding-number", "equation:two-band-hamiltonian-d-dot-sigma"], "related_units": ["concept:nielsen-ninomiya-theorem", "derivation:stokes-theorem-implies-net-zero-charge"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "method:berry-flux-diagnosis-of-node-charge", "type": "method", "title": "Berry-Flux Diagnosis Of Node Charge", "summary": "To determine the charge of an isolated Weyl node, surround it by a small sphere in momentum space, compute the Berry curvature of the occupied state, and integrate the flux over the sphere.", "path": "units/methods/berry-flux-diagnosis-of-node-charge.json", "domain": "topological-phases-of-matter", "subdomain": "diagnostics", "tags": ["method", "berry-flux", "weyl-node"], "aliases": [], "dependencies": ["concept:berry-curvature", "equation:berry-flux-topological-charge", "quantity:winding-number"], "related_units": ["derivation:berry-flux-gives-node-charge", "bridge:weyl-node-to-berry-monopole"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "working", "source_anchor_count": 1}
{"id": "model:two-band-lattice-weyl-model", "type": "model", "title": "Two-Band Lattice Weyl Model", "summary": "A simple periodic two-band lattice Hamiltonian provides an explicit realization of Weyl nodes on a Brillouin torus and makes the global doubling constraint visible.", "path": "units/models/two-band-lattice-weyl-model.json", "domain": "topological-phases-of-matter", "subdomain": "toy-models", "tags": ["lattice-model", "weyl-semimetal", "fermion-doubling"], "aliases": [], "dependencies": ["concept:weyl-node", "concept:nielsen-ninomiya-theorem"], "related_units": ["equation:two-band-weyl-model-with-tunable-pair", "warning:local-weyl-description-does-not-fix-global-lattice-consistency"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "seed", "source_anchor_count": 1}
{"id": "quantity:berry-curvature-two-form", "type": "quantity", "title": "Berry Curvature Two-Form", "summary": "The Berry curvature two-form F is the gauge-invariant curvature of the Berry connection and integrates to the first Chern number on closed surfaces.", "path": "units/quantities/berry-curvature-two-form.json", "domain": "topological-phases-of-matter", "subdomain": "berry-geometry", "tags": ["berry-curvature", "two-form", "chern-number"], "aliases": ["F"], "dependencies": ["concept:berry-connection"], "related_units": ["concept:berry-curvature", "equation:berry-flux-topological-charge"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "stable", "source_anchor_count": 1}
{"id": "quantity:chirality-sign", "type": "quantity", "title": "Chirality Sign", "summary": "The chirality sign is the plus or minus label attached to a Weyl node by the sign of the Jacobian determinant of the local linearized map.", "path": "units/quantities/chirality-sign.json", "domain": "topological-phases-of-matter", "subdomain": "weyl-semimetals", "tags": ["chirality", "sign", "weyl-node"], "aliases": ["handedness sign"], "dependencies": [], "related_units": ["concept:chirality-of-weyl-node", "claim:lattice-weyl-nodes-sum-to-zero-net-chirality"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "stable", "source_anchor_count": 1}
{"id": "quantity:fermi-energy", "type": "quantity", "title": "Fermi Energy", "summary": "The Fermi energy is the reference energy that determines which band crossings control low-energy excitations; a crossing away from it does not automatically define a Weyl semimetal phase.", "path": "units/quantities/fermi-energy.json", "domain": "topological-phases-of-matter", "subdomain": "low-energy-kinematics", "tags": ["fermi-energy", "semimetal", "low-energy-physics"], "aliases": [], "dependencies": [], "related_units": ["warning:crossing-away-from-fermi-energy-is-not-yet-a-clean-weyl-semimetal", "concept:band-crossing"], "formalization_status": "not_started", "validation_status": "source-grounded", "maturity": "stable", "source_anchor_count": 1}
