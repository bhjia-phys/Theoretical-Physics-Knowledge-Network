{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Physics KB Regression Suite",
  "type": "object",
  "required": [
    "suite_id",
    "title",
    "topic",
    "summary",
    "source_map_id",
    "question_ids",
    "oracle_ids",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "suite_id": {
      "type": "string",
      "pattern": "^regression_suite:[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "topic": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "source_map_id": {
      "type": "string",
      "pattern": "^source_map:[a-z0-9-]+$"
    },
    "question_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^regression_question:[a-z0-9-]+$"
      }
    },
    "oracle_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^question_oracle:[a-z0-9-]+$"
      }
    },
    "focus_units": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}
