{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Physics KB Regression Run Log",
  "type": "object",
  "required": [
    "run_id",
    "suite_id",
    "status",
    "results",
    "created_at"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^regression_run:[a-z0-9-]+$"
    },
    "suite_id": {
      "type": "string",
      "pattern": "^regression_suite:[a-z0-9-]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "mixed",
        "fail"
      ]
    },
    "topic_completion_status": {
      "type": "string",
      "enum": [
        "not_assessed",
        "gap-aware",
        "regression-seeded",
        "regression-stable",
        "promotion-blocked",
        "promotion-ready"
      ]
    },
    "promotion_readiness": {
      "type": "string",
      "enum": [
        "not-assessed",
        "ready",
        "blocked",
        "future-buffer"
      ]
    },
    "blocking_unit_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "oracle_id",
          "grade"
        ],
        "properties": {
          "question_id": {
            "type": "string",
            "pattern": "^regression_question:[a-z0-9-]+$"
          },
          "oracle_id": {
            "type": "string",
            "pattern": "^question_oracle:[a-z0-9-]+$"
          },
          "grade": {
            "type": "string",
            "enum": [
              "pass",
              "unsafe-pass",
              "partial",
              "fail"
            ]
          },
          "notes": {
            "type": "string"
          },
          "writeback_unit_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z_]+:[a-z0-9-]+$"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "created_at": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}
