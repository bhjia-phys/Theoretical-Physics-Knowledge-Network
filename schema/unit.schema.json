{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Physics KB Unit",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "summary",
    "domain",
    "tags",
    "aliases",
    "assumptions",
    "regime",
    "scope",
    "dependencies",
    "related_units",
    "source_anchors",
    "formalization_status",
    "validation_status",
    "maturity",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z_]+:[a-z0-9-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "concept",
        "definition",
        "theorem",
        "lemma",
        "equivalence",
        "conjecture",
        "theorem_family",
        "definition_family",
        "notation_family",
        "feasibility_question",
        "dependency_request",
        "proof_search_request",
        "equation",
        "equation_context",
        "quantity",
        "claim",
        "derivation",
        "proof_fragment",
        "proof_obligation",
        "proof_state",
        "derivation_step",
        "dependency_graph_snapshot",
        "method",
        "model",
        "warning",
        "bridge",
        "notation_map",
        "source_fusion_record",
        "conflict_record",
        "open_gap",
        "question_oracle",
        "regression_question",
        "followup_source_task",
        "source_map"
      ]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "subdomain": {
      "type": "string"
    },
    "canonical_family": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "regime": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "related_units": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "source_anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_anchor"
      }
    },
    "formalization_status": {
      "type": "string",
      "enum": [
        "not_started",
        "candidate",
        "scaffolded",
        "partial",
        "reviewed"
      ]
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "source-grounded",
        "cross-checked",
        "formalized",
        "validated"
      ]
    },
    "maturity": {
      "type": "string",
      "enum": [
        "seed",
        "working",
        "stable"
      ]
    },
    "symmetries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "representation": {
      "type": "string"
    },
    "human_projection_profile": {
      "type": "string",
      "enum": [
        "card",
        "learning-note"
      ]
    },
    "motivation": {
      "type": "string"
    },
    "prerequisite_story": {
      "type": "string"
    },
    "local_context_story": {
      "type": "string"
    },
    "forward_links_story": {
      "type": "string"
    },
    "canonical_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope_boundaries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "math_expressions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/math_expression"
      }
    },
    "model_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "equation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "quantity_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formal_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formal_theory_role": {
      "type": "string",
      "enum": [
        "trusted_target",
        "intermediate_theory",
        "supporting_context"
      ]
    },
    "definition_trust_tier": {
      "type": "string",
      "enum": [
        "trusted",
        "reviewed_translation",
        "provisional",
        "scaffold_only"
      ]
    },
    "statement_graph_role": {
      "type": "string",
      "enum": [
        "target_statement",
        "prerequisite",
        "intermediate_lemma",
        "temporary_scaffold",
        "explanatory_bridge"
      ]
    },
    "statement_graph_parents": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "statement_graph_children": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "target_statement_id": {
      "type": "string",
      "pattern": "^[a-z_]+:[a-z0-9-]+$"
    },
    "faithfulness_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "pending",
        "bounded",
        "reviewed"
      ]
    },
    "faithfulness_strategy": {
      "type": "string"
    },
    "faithfulness_notes": {
      "type": "string"
    },
    "comparator_audit_status": {
      "type": "string",
      "enum": [
        "not_applicable",
        "pending",
        "passed",
        "failed"
      ]
    },
    "comparator_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "provenance_kind": {
      "type": "string",
      "enum": [
        "source_derived",
        "retrieved_existing_formalization",
        "adapted_existing_formalization",
        "generated_from_scratch",
        "mixed"
      ]
    },
    "attribution_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prerequisite_closure_status": {
      "type": "string",
      "enum": [
        "not_needed",
        "pending",
        "partial",
        "closed"
      ]
    },
    "lean_namespace": {
      "type": "string"
    },
    "lean_declaration": {
      "type": "string"
    },
    "lean_statement_kind": {
      "type": "string"
    },
    "admissible_assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lean_prerequisite_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "formalization_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retrieval_hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/symbol_entry"
      }
    },
    "step_inputs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "step_output": {
      "type": "string",
      "pattern": "^[a-z_]+:[a-z0-9-]+$"
    },
    "step_justification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_omission_flag": {
      "type": "boolean"
    },
    "followup_required": {
      "type": "boolean"
    },
    "gap_kind": {
      "type": "string"
    },
    "recovery_source_type": {
      "type": "string"
    },
    "task_status": {
      "type": "string"
    },
    "reentry_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "future_buffered": {
      "type": "boolean"
    },
    "runtime_gap_kinds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime_return_to_stages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "topic_queue_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^queue:[a-z0-9-]+$"
      }
    },
    "topic_completion_status": {
      "type": "string",
      "enum": [
        "not_assessed",
        "gap-aware",
        "regression-seeded",
        "regression-stable",
        "promotion-blocked",
        "promotion-ready"
      ]
    },
    "supporting_regression_question_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^regression_question:[a-z0-9-]+$"
      }
    },
    "supporting_oracle_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^question_oracle:[a-z0-9-]+$"
      }
    },
    "supporting_regression_run_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^regression_run:[a-z0-9-]+$"
      }
    },
    "promotion_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "split_required": {
      "type": "boolean"
    },
    "recovery_source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prompt": {
      "type": "string"
    },
    "question_family": {
      "type": "string"
    },
    "primary_retrieval_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "pass_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mandatory_unit_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "mandatory_equation_labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "obligation_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^proof_obligation:[a-z0-9-]+$"
      }
    },
    "supporting_obligation_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^proof_obligation:[a-z0-9-]+$"
      }
    },
    "equation_context_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^equation_context:[a-z0-9-]+$"
      }
    },
    "dependency_graph_snapshot_id": {
      "type": "string",
      "pattern": "^dependency_graph_snapshot:[a-z0-9-]+$"
    },
    "family_member_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "fusion_member_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "conflict_unit_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "derivation_spine": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mandatory_logical_moves": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "common_failure_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "grading_rubric": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_triggers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_units": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "resolution_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "resolves_gaps": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^open_gap:[a-z0-9-]+$"
      }
    },
    "routes_back_to": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z_]+:[a-z0-9-]+$"
      }
    },
    "candidate_sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate_source"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    }
  },
  "$defs": {
    "source_anchor": {
      "type": "object",
      "required": [
        "source_id",
        "section"
      ],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "equation_labels": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "figure_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "symbol_entry": {
      "type": "object",
      "required": [
        "symbol",
        "meaning"
      ],
      "properties": {
        "symbol": {
          "type": "string"
        },
        "meaning": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "math_expression": {
      "type": "object",
      "required": [
        "latex"
      ],
      "properties": {
        "latex": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "equation_label": {
          "type": "string"
        },
        "context": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "candidate_source": {
      "type": "object",
      "required": [
        "citation"
      ],
      "properties": {
        "citation": {
          "type": "string"
        },
        "why": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
